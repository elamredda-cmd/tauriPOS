{
  "name": "tauri-app",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "npm run check:tauri-commands && vite build",
    "preview": "vite preview",
    "check": "npm run check:tauri-commands && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:tauri-commands": "node scripts/check-tauri-command-permissions.mjs",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "pack:printer-module": "node scripts/pack-printer-module.mjs",
    "verify:printer-module": "node scripts/verify-printer-module.mjs",
    "build:printer-module:star": "node scripts/build-star-printer-module.mjs",
    "tauri": "tauri",
    "test:commerce": "cd src-tauri && cargo test commerce::tests",
    "test:printers": "vitest run src/lib/printers.test.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@lucide/svelte": "^1.25.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "firebase": "^12.16.0",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@types/qrcode": "^1.5.5",
    "fflate": "^0.8.3",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vitest": "^4.1.10",
    "vite": "^6.0.3"
  }
}
