{
  "name": "tauri-app",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "tauri:till1": "POS_PROFILE=till1 VITE_POS_PROFILE=till1 VITE_PORT=1420 tauri dev --config src-tauri/tauri.till1.conf.json",
    "tauri:till2": "POS_PROFILE=till2 VITE_POS_PROFILE=till2 VITE_PORT=1430 tauri dev --config src-tauri/tauri.till2.conf.json",
    "test:commerce": "cd src-tauri && cargo test commerce::tests"
  },
  "license": "MIT",
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
